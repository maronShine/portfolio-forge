// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  firstName     String
  lastName      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  portfolios    Portfolio[]
}

model Portfolio {
  id            String      @id @default(cuid())
  slug          String      @unique
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hero
  title         String
  tagline       String
  photoUrl      String?
  stats         Json?       // [{label, value}]
  ctaText       String?

  // About
  about         String?
  differentiators Json?     // [string]
  values        Json?       // [string]
  cvUrl         String?

  // Services
  services      Json?       // [{title, description, deliverables, duration, forWho}]

  // Experience
  experiences   Json?       // [{role, org, period, description, results}]

  // Projects
  projects      Json?       // [{title, context, problem, role, results, learning, imageUrl}]

  // Skills
  skills        Json?       // [{name, level}]
  tools         Json?       // [string]
  certifications Json?      // [{title, org, year}]
  languages     Json?       // [{language, level}]

  // Contact
  email         String?
  phone         String?
  linkedin      String?
  website       String?
  location      String?
  availability  String?     // "available" | "busy" | "on-project"

  isPublic      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
